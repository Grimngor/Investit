# Backend settings
SECRET_KEY=change-me
ACCESS_TOKEN_EXPIRE_MINUTES=30
PRICE_STALE_THRESHOLD_DAYS=3
BACKEND_CORS_ORIGINS=["http://localhost:5174","http://127.0.0.1:5174"]
PERSISTENCE_BACKEND=sqlite
DATABASE_PATH=data/investit.sqlite3

# Optional email allowlist and trusted-proxy authentication for Tailscale Serve identity headers.
# When the allowlist is populated, registration, password login, and Tailscale login are restricted to these emails.
# Leave trusted-proxy auth disabled unless the app is reachable only through the localhost-bound web proxy.
TRUSTED_PROXY_AUTH_ENABLED=false
TRUSTED_PROXY_AUTH_ALLOWED_EMAILS=
TRUSTED_PROXY_AUTH_HEADER_EMAIL=Tailscale-User-Login
TRUSTED_PROXY_AUTH_HEADER_NAME=Tailscale-User-Name

# Docker Compose web proxy port. The proxy binds to 127.0.0.1 only.
INVESTIT_WEB_PORT=8080

# Docker Compose host data directory. Use .cache/docker-data for isolated local Docker tests.
INVESTIT_DATA_DIR=./data

# Optional market-data provider key. Leave blank to use unauthenticated providers only.
FINNHUB_API_KEY=

# Optional OpenFIGI key. Leave blank to use unauthenticated mapping with lower rate limits.
OPENFIGI_API_KEY=

# Optional Gmail-backed MyInvestor import. Use gmail.readonly in the Google OAuth consent screen.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Leave blank to derive from the request; set explicitly for deployed OAuth redirect URIs if needed.
GMAIL_OAUTH_REDIRECT_URI=
GMAIL_IMPORT_MAX_MESSAGES=20
GMAIL_IMPORT_QUERY='from:notificaciones@myinvestor.es ("CONFIRMACION DE OPERACION DE VALORES" OR "CONFIRMACIÓN DE OPERACIÓN DE VALORES" OR "Codigo ISIN" OR "Código ISIN") newer_than:365d'
